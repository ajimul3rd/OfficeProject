<!--Open Dialog for New Project-->
<XAddProjectDialog 
OnSave="@HandleProjectSave"
showModal="@showProjectDialog"
ProjectTitle="New Project"
projectId="@projectId"
clientId="@clientId" />

@code {

    private EditContext? editContext;
    private string statusMessage = string.Empty;  // Status message to display to user
    private bool isError = false;               // Determines if message is error/success
    private bool isSubmitting = false;          // Tracks form submission state
    private bool showAddForm = false;           // Controls form visibility
    private List<ClientsDTO> clients = new();   // List of clients
    private ClientsDTO currentClient = new();   // Currently selected client
    private ValidationMessageStore? messageStore; // Validation message store
    private ProjectsDTO projectsDTO = new();    // Project DTO instance
    private readonly Dictionary<FieldIdentifier, bool> _touchedFields = new(); // Tracks touched fields
    private bool cardmode = false;


    // Add new project Dialog implementation

    private bool showProjectDialog = false;
    // private AddProjectDialog newProjectDialog;

    private void ShowProjectDialog() => showProjectDialog = true;

    private async Task HandleProjectSave(bool success)
    {
        projectId = 0;
        clientId = 0;
        showProjectDialog = false;
        if (success)
        { 

            await LoadProjects(); // Reload data after successful save
            StateHasChanged();
        }
    }      

    private async Task HandleDevelopmentSave(bool success)
    {
        showProjectDialog = false;
        if (success)
        {
            await LoadProjects();
        }
    }


    // Form model bound to the UI
    [SupplyParameterFromForm]
    private ClientsDTO? Model { get; set; }

    // =============================================
    // FORM VISIBILITY CONTROL METHODS
    // =============================================
    private void ToggleAddForm()
    {
        showAddForm = !showAddForm;
        digitalMarketingTapPanShowDialog = false;
        webDevelopTapPanShowDialog = false;

    }

    private void ToggleAddCancelForm()
    {
        showAddForm = !showAddForm;
        digitalMarketingTapPanShowDialog = false;
        webDevelopTapPanShowDialog = false; ;
    }

    private void EditClient(ClientsDTO client)
    {
        currentClient = client;
        showAddForm = !showAddForm;
        digitalMarketingTapPanShowDialog = false;
        webDevelopTapPanShowDialog = false;

    }
    //***************************

    private void OnProjectTypeChanged(ChangeEventArgs e)
    {

        Console.WriteLine("Changes reflected");
        StateHasChanged(); // Notify Blazor to update UI
    }

    //****************************************/
    // =============================================
    // FIELD TRACKING AND VALIDATION METHODS
    // =============================================

    private void MarkAsTouched<T>(Expression<Func<T>> fieldAccessor)
    {
        var fieldIdentifier = FieldIdentifier.Create(fieldAccessor);
        if (!_touchedFields.ContainsKey(fieldIdentifier))
        {
            _touchedFields[fieldIdentifier] = true;
            ValidateClientSingleField(fieldIdentifier);
            editContext?.NotifyValidationStateChanged();
        }
    }

    private void MarkAsTouchedProject<T>(Expression<Func<T>> fieldAccessor)
    {
        var fieldIdentifier = FieldIdentifier.Create(fieldAccessor);
        if (!_touchedFields.ContainsKey(fieldIdentifier))
        {
            _touchedFields[fieldIdentifier] = true;
            editContext?.NotifyValidationStateChanged();
        }
    }

    // =============================================
    // CLIENT VALIDATION LOGIC
    // =============================================
    private void ValidateClientSingleField(FieldIdentifier fieldIdentifier)
    {
        messageStore?.Clear(fieldIdentifier);

        if (!_touchedFields.TryGetValue(fieldIdentifier, out var isTouched) || !isTouched)
            return;

        switch (fieldIdentifier.FieldName)
        {
            case nameof(Model.ClientName):
                if (string.IsNullOrWhiteSpace(Model.ClientName))
                    messageStore?.Add(fieldIdentifier, "Client name is required.");
                break;

            case nameof(Model.CompanyName):
                if (string.IsNullOrWhiteSpace(Model.CompanyName))
                    messageStore?.Add(fieldIdentifier, "Company name is required.");
                break;

            case nameof(Model.ClientContact1):
                if (string.IsNullOrWhiteSpace(Model.ClientContact1))
                    messageStore?.Add(fieldIdentifier, "Primary contact is required.");
                break;

            case nameof(Model.ClientEmail1):
                if (string.IsNullOrWhiteSpace(Model.ClientEmail1))
                    messageStore?.Add(fieldIdentifier, "Primary email is required.");
                else if (!new EmailAddressAttribute().IsValid(Model.ClientEmail1))
                    messageStore?.Add(fieldIdentifier, "Please enter a valid email address.");
                break;

            case nameof(Model.IssueDate):
                if (Model.IssueDate == null)
                    messageStore?.Add(fieldIdentifier, "Issue date is required.");
                break;

            case nameof(Model.IssuedBy):
                if (string.IsNullOrWhiteSpace(Model.IssuedBy))
                    messageStore?.Add(fieldIdentifier, "Issued by is required.");
                break;
        }
    }

    // =============================================
    // FORM INITIALIZATION
    // =============================================
    protected override void OnInitialized()
    {
        Model ??= new ClientsDTO()
            {

                IssueDate = DateTime.Now,
                IsActive = true,
                ClientCreatedAt = DateTime.Now
            };


        editContext = new(Model);
        editContext.OnValidationRequested += HandleValidationRequested;
        editContext.OnFieldChanged += HandleFieldChanged;
        messageStore = new(editContext);
    }

    // =============================================
    // COMPREHENSIVE VALIDATION METHODS
    // =============================================
    private void customClientValidation()
    {
        if (string.IsNullOrWhiteSpace(Model.ClientName))
            messageStore?.Add(() => Model.ClientName, "Client name is required.");

        if (string.IsNullOrWhiteSpace(Model.CompanyName))
            messageStore?.Add(() => Model.CompanyName, "Company name is required.");

        if (string.IsNullOrWhiteSpace(Model.ClientContact1))
            messageStore?.Add(() => Model.ClientContact1, "Primary contact is required.");

        if (string.IsNullOrWhiteSpace(Model.ClientEmail1))
            messageStore?.Add(() => Model.ClientEmail1, "Primary email is required.");
        else if (!new EmailAddressAttribute().IsValid(Model.ClientEmail1))
            messageStore?.Add(() => Model.ClientEmail1, "Please enter a valid email address.");

        if (Model.IssueDate == null)
            messageStore?.Add(() => Model.IssueDate, "Issue date is required.");

        if (string.IsNullOrWhiteSpace(Model.IssuedBy))
            messageStore?.Add(() => Model.IssuedBy, "Issued by is required.");
    }

    private void HandleValidationRequested(object? sender, ValidationRequestedEventArgs args)
    {
        messageStore?.Clear();
        customClientValidation();
        editContext?.NotifyValidationStateChanged();
    }


    // =============================================
    // FORM SUBMISSION HANDLER
    // =============================================
    private async Task Submit()
    {
        try
        {
            if (editContext!.Validate())
            {
                var response = await ApiService.AddSingleClientAsync(Model!);

                if (response.IsSuccessStatusCode)
                {
                    ResetForm();
                    statusMessage = "Client added successfully!";
                    showAddForm = !showAddForm;
                    await LoadProjects();
                    isError = false;
                }
                else
                {
                    var errorContent = await response.Content.ReadAsStringAsync();
                    statusMessage = $"Error adding client: {errorContent}";
                    isError = true;
                }
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Exception when adding client: {ex.Message}";
            isError = true;
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    // =============================================
    // FORM RESET METHOD
    // =============================================
    private void ResetForm()
    {
        Model = new ClientsDTO()
            {
                IssueDate = DateTime.Now,
                IsActive = true,
                ClientCreatedAt = DateTime.Now
            };

        editContext = new EditContext(Model);
        editContext.OnValidationRequested += HandleValidationRequested;
        editContext.OnFieldChanged += HandleFieldChanged;
        messageStore = new ValidationMessageStore(editContext);

        Task.Delay(3000).ContinueWith(_ =>
        {
            statusMessage = string.Empty;
            StateHasChanged();
        });
    }

    // =============================================
    // HELPER METHODS
    // =============================================
    private object? GetFieldValue(FieldIdentifier fieldIdentifier)
    {
        var property = fieldIdentifier.Model.GetType().GetProperty(fieldIdentifier.FieldName);
        return property?.GetValue(fieldIdentifier.Model);
    }

    private void HandleFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        _touchedFields[e.FieldIdentifier] = true;
        messageStore?.Clear(e.FieldIdentifier);
    }
    //===========================
    // Dialog Code Here!
    //============================

    private Pages.DialogModel.XWebDevelopmentTabPanDialog webDevelopmentprojectDialog;

    private Pages.DialogModel.XDigitalMarketingTabPanDialog digitalMarketingprojectDialog;

    // private ProjectsDTO selectedProject = new ProjectsDTO();

    public int projectId { get; set; } = 0;

    public int clientId { get; set; } = 0;

    public string clientName { get; set; } = "Client: Not Selected";

    private bool webDevelopTapPanShowDialog = false;

    private bool digitalMarketingTapPanShowDialog = false;

    private void ShowModal(ProjectsDTO project)
    {
        // selectedProject = project;
        if (project.ProjectType == ProjectType.WEB_DEVELOPMENT)
        {
            digitalMarketingTapPanShowDialog = false;
            webDevelopTapPanShowDialog = true;
            projectId = (int)project.ProjectId!;
            StateHasChanged();// Ensure UI updates
            clientName = "Project: " + project.ProjectName!;
        }
        else if (project.ProjectType == ProjectType.DIGITAL_MARKETING)
        {
            digitalMarketingTapPanShowDialog = true;
            webDevelopTapPanShowDialog = false;
            projectId = (int)project.ProjectId!;
            StateHasChanged();// Ensure UI updates
            clientName = "Project: " + project.ProjectName!;
        }

       
    }


    private async Task ShowModalForNewProject(ClientsDTO Client)
    {
        projectId = 0;
        clientId = (int)Client.ClientId!;
        clientName = "Client: " + Client.ClientName!;
        digitalMarketingTapPanShowDialog = false;
        webDevelopTapPanShowDialog = false;
        showProjectDialog = true;
        StateHasChanged();
    }

    //Table data implementation

    private string searchText = "";

    private string selectedFilter = "all";

    private bool showCardView = true;

    private bool isTableView = true;

    private void ToggleView()
    {
        isTableView = !isTableView;
        showCardView = !showCardView;
        digitalMarketingTapPanShowDialog = false;
        webDevelopTapPanShowDialog = false;
    }

    private List<ClientsDTO> tableData = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();

    }


    private async Task ReloadProjects(bool isSuccess)
    {
        projectId = 0;
       clientId = 0;
        if (isSuccess)
        {
          
            await LoadProjects();
            
        }

  

    }

    private async Task LoadProjects()
    {
        try
        {
            tableData = await ApiService.GetClientListAsync() ?? new List<ClientsDTO>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading clients: {ex.Message}");
        }
    }


    private IEnumerable<ClientsDTO> FilteredClients =>
        tableData.Where(c =>
            (string.IsNullOrWhiteSpace(searchText) ||
             c.ClientName.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
             c.CompanyName.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            &&
            (selectedFilter == "all" ||
             (selectedFilter == "active" && c.IsActive) ||
             (selectedFilter == "inactive" && !c.IsActive))
        );


}




















<!--Dialog Styles-->
<style>
    /* ProjectDialog.razor.css */
    .project-dialog-container {
        position: relative;
    }

    .modal {
        background-color: rgba(0, 0, 0, 0.5);
    }

    .modal-content {
        border-radius: 0.5rem;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
    }

    .modal-header {
        border-bottom: 1px solid #dee2e6;
        padding: 1rem 1.5rem;
    }

    .modal-title {
        font-weight: 600;
        color: #2c3e50;
    }

    .modal-body {
        padding: 1.5rem;
    }

    .nav-tabs {
        border-bottom: 1px solid #dee2e6;
    }

        .nav-tabs .nav-link {
            color: #495057;
            border: none;
            padding: 0.75rem 1.25rem;
            font-weight: 500;
        }

            .nav-tabs .nav-link.active {
                color: #0d6efd;
                background-color: transparent;
                border-bottom: 2px solid #0d6efd;
            }

            .nav-tabs .nav-link:hover {
                border-color: transparent;
                color: #0d6efd;
            }

    .form-group {
        margin-bottom: 1.25rem;
    }

        .form-group label {
            font-weight: 500;
            margin-bottom: 0.5rem;
            display: block;
        }

    .task-card {
        border-left: 4px solid #6c757d;
        transition: all 0.3s ease;
    }

        .task-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        }

        .task-card.status-pending {
            border-left-color: #fd7e14;
        }

        .task-card.status-completed {
            border-left-color: #198754;
        }

        .task-card.status-open {
            border-left-color: #dc3545;
