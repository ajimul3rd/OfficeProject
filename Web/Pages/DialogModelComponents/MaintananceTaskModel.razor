@*     private async Task InitializeMaintanancePhase() *@
@*     { *@
@*         try *@
@*         { *@
@*             if (MaintenanceId > 0) *@
@*             { *@
@*                 var getData = await apiService.GetMaintenancePhaseByIdAsync(MaintenanceId); *@
@*                 if (getData != null) *@
