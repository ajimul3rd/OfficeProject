@if (SeoServiceDetails != null && SeoServiceDetails.Any())
{
    <div class="table-responsive mt-3">
        <table class="table table-bordered table-hover">
            <thead class="table-primary">
                <tr>
                    <th>#</th>
                    <th>Keyword</th>
                    <th>Current Rank</th>
                    <th>Notes</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var detail in SeoServiceDetails)
                {
                    <tr>
                        <td>@detail.SeoServiceDetailsId</td>
                        <td>@detail.KeyWord</td>
                        <td>@detail.Rank</td>
                        <td>@detail.Note</td>
                        <td>
                            <button class="btn btn-sm btn-primary"
                                    @onclick="() => AddWorkRecord(detail)">
                                <i class="fas fa-plus"></i> Add Work
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info mt-3">
        No SEO service details found.
    </div>
}

@code {
    [Parameter]
    public List<SeoServiceDetailModel> SeoServiceDetails { get; set; } = GetDummyData();

    [Parameter]
    public EventCallback<SeoServiceDetailModel> OnAddWorkRecord { get; set; }

    private async Task AddWorkRecord(SeoServiceDetailModel detail)
    {
        await OnAddWorkRecord.InvokeAsync(detail);
    }

