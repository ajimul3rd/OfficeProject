@if (OthersServices != null && OthersServices.Any())
{
    <div class="table-responsive mt-3">
        <table class="table table-bordered table-hover">
            <thead class="table-secondary">
                <tr>
                    <th>#</th>
                    <th>Label Name</th>
                    <th>Post</th>
                    <th>Note</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var service in OthersServices)
                {
                    <tr>
                        <td>@service.OthersId</td>
                        <td>@service.LableName</td>
                        <td>@service.Post</td>
                        <td>@service.Note</td>
                        <td>
                            <button class="btn btn-sm btn-primary"
                                    @onclick="() => AddWorkRecord(service)">
                                <i class="fas fa-plus"></i> Add Work
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-warning mt-3">
        No other services found.
    </div>
}

@code {
    [Parameter]
    public List<OthersServiceModel> OthersServices { get; set; } = GetDummyOthersData();

    [Parameter]
    public EventCallback<OthersServiceModel> OnAddWorkRecord { get; set; }

    private async Task AddWorkRecord(OthersServiceModel service)
    {
        await OnAddWorkRecord.InvokeAsync(service);
    }

    private static List<OthersServiceModel> GetDummyOthersData()
    {
        return new List<OthersServiceModel>
        {
            new()
            {
                OthersId = 1,
                ServiceId = 1,
                LableName = "Best Coffee House",
                Post = 5,
                Note = "Good improvement after GMB optimization",
                ExtraField1 = "",
                ExtraField2 = ""
            },
            new()
            {
                OthersId = 2,
                ServiceId = 1,
                LableName = "Downtown Espresso Bar",
                Post = 3,
                Note = "New photos uploaded to listing",
                ExtraField1 = "",
                ExtraField2 = ""
            }
        };
    }

    public class OthersServiceModel
    {
        public int OthersId { get; set; }
        public int ServiceId { get; set; }
        public string LableName { get; set; }
        public int Post { get; set; }
        public string Note { get; set; }
        public string ExtraField1 { get; set; }
        public string ExtraField2 { get; set; }
    }
}
