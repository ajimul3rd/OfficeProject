    private async Task LoadWorkList()
    {
        try
        {
            var workTasks = await api.GetWorkingRecordPerUserAsync();

            tableData = workTasks;

            Console.WriteLine($"tableData count: {tableData.Count}");
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading work records: " + ex.Message);
            tableData = new();
           
        }
    }

    private void EditWorkTask(WorkTaskDetailsDto work)
    {
        IsVisible = true;
        ShowDialog = false;
        WorkRecord ??=new WorkTaskDetailsDto();
        WorkRecord = work;

    }



    private async Task ReloadWorkTask(bool isSuccess)
    {
        Console.WriteLine(isSuccess);
        if (isSuccess)
        {
            await LoadWorkList(); 
            StateHasChanged(); 
        }
        else
        {
            IsVisible = false;
        }
    }


    @inject IDataSerializer? DataSerializer;
    private void OnRowClick(WorkTaskDetailsDto item)
    {
        ShowDialog = true;
        workTaskId = (int)item.WorkRecordId!;
        // DataSerializer?.Serializer(item, "Submission Error");
    }
